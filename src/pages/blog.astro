---
import BaseHead from '../components/BaseHead.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { SITE_TITLE, SITE_DESCRIPTION } from '../config.js'
import BlogListItem from '../components/WPBlogListItem.astro'
import HorizontalLine from '../components/HorizontalLine.astro'

const postFiles = import.meta.glob('./blog/*.md', { eager: true })

const posts = Object.entries(postFiles)
  .map(([path, post]: [string, any]) => ({
    id: 0,
    title: post.frontmatter?.title || '',
    description: post.frontmatter?.description || '',
    content: post.compiledContent?.() || '',
    pubDate: post.frontmatter?.date || '',
    updatedDate: post.frontmatter?.updated || '',
    heroImage: post.frontmatter?.heroImage || '',
    tags: post.frontmatter?.tags || [],
    slug: path.replace('./blog/', '').replace('.md', ''),
    url: `/blog/${path.replace('./blog/', '').replace('.md', '')}`,
    categories: post.frontmatter?.categories || [],
  }))
  .filter((post: any) => post.title)
  .sort((a: any, b: any) => (new Date(a.pubDate) > new Date(b.pubDate) ? -1 : 1))
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			ul {
				list-style-type: none;
				padding: unset;
				margin: 0;
			}

			ul li time {
				flex: 0 0 130px;
				font-style: italic;
				color: #595959;
			}

			ul li a:visited {
				color: #8e32dc;
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="pb-32">
			<section>
				<HorizontalLine />
				<ul>
					{
						posts.map((post: Post) => (
							<li>
								<div>
									<div class="my-4">
										<BlogListItem post={post} />
									</div>
									<HorizontalLine />
								</div>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
